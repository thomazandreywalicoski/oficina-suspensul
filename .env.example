# Copie este arquivo para .env e preencha com seus valores reais
# O .env real está no .gitignore e NÃO é commitado

SECRET_KEY=coloque-uma-chave-secreta-aqui
SESSION_COOKIE_SECURE=true
ADMIN_EMAIL=seu-email@exemplo.com
ADMIN_PASSWORD=sua-senha-aqui
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_SECONDS=7200

DB_HOST=mysql
DB_PORT=3306
DB_USER=suspensul
DB_PASSWORD=senha-do-mysql-aqui
DB_NAME=oficina_suspensul

FLASK_ENV=production

PUBLIC_BASE_URL=https://oficinasuspensul.com.br
